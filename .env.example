# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git!

# Speckle Authentication Token
VITE_SPECKLE_TOKEN=your_token_here

# Project Configuration
VITE_PROJECT_ID=your_project_id
VITE_MODEL_ID=your_model_id

# Automate Function IDs
VITE_PIE_CHART_FUNCTION_ID=your_function_id
VITE_VALIDATOR_FUNCTION_ID=your_function_id
```

